		Color(0.68, 0.61, 0.56),
		5, 8, 2
	)

static func wall_rough_stone() -> ImageTexture:
	var width = 64
	var height = 64
	var img = Image.create(width, height, false, Image.FORMAT_RGB8)

	var stone_a = Color(0.46, 0.21, 0.14)
	var stone_b = Color(0.54, 0.26, 0.18)
	var mortar  = Color(0.68, 0.61, 0.56)

	var cw = width / 2.0
	var ch = height / 2.0
	var mt = 4

	for y in range(height):
		for x in range(width):
			var lx = fmod(x, cw)
			var ly = fmod(y, ch)
			var block = int(x / cw) + int(y / ch) * 2

			if lx < mt or ly < mt:
				img.set_pixel(x, y, mortar)
			else:
				var base = stone_a if block % 2 == 0 else stone_b
				var noise = randf_range(-0.04, 0.04)

				if randf() < 0.012:
					img.set_pixel(x, y, Color(0.25, 0.12, 0.08))
				else:
					img.set_pixel(x, y, Color(
						clamp(base.r + noise, 0.0, 1.0),
						clamp(base.g + noise, 0.0, 1.0),
						clamp(base.b + noise, 0.0, 1.0)
					))

	return ImageTexture.create_from_image(img)


# ─── HELPERS ──────────────────────────────────────────────────────────────────

static func _make_brick(width: int, height: int,
		brick_a: Color, brick_b: Color, mortar: Color,
		rows: int, cols: int, mortar_px: int) -> ImageTexture:

	var img = Image.create(width, height, false, Image.FORMAT_RGB8)

	var rh = height / float(rows)
	var cw = width / float(cols)

	for y in range(height):
		var row = int(y / rh)
		var local_y = fmod(y, rh)
		var offset = (cw / 2.0) if row % 2 == 1 else 0.0

		for x in range(width):
			var sx = fmod(x + offset, width)
			var col = int(sx / cw)
			var local_x = fmod(sx, cw)

			if local_y < mortar_px or local_x < mortar_px:
				img.set_pixel(x, y, mortar)
			else:
				var base = brick_a if (row + col) % 2 == 0 else brick_b
				var noise = randf_range(-0.03, 0.03)

				img.set_pixel(x, y, Color(
					clamp(base.r + noise, 0.0, 1.0),
					clamp(base.g + noise, 0.0, 1.0),
					clamp(base.b + noise, 0.0, 1.0)
				))

	return ImageTexture.create_from_image(img)

static func _make_cobble(width: int, height: int,
		stone_a: Color, stone_b: Color, mortar: Color,
		cols: int, rows: int, mortar_px: int, corner_r: int) -> ImageTexture:

	var img = Image.create(width, height, false, Image.FORMAT_RGB8)

	var cw = width / float(cols)
	var ch = height / float(rows)

	for y in range(height):
		for x in range(width):
			var row = int(y / ch)
			var col = int(x / cw)

			var lx = fmod(x, cw)
			var ly = fmod(y, ch)

			if lx < mortar_px or ly < mortar_px:
				img.set_pixel(x, y, mortar)
				continue

			var cx = lx - mortar_px
			var cy = ly - mortar_px
			var sw = cw - mortar_px
			var sh = ch - mortar_px

			var in_corner = false

			if cx < corner_r and cy < corner_r:
				in_corner = Vector2(cx, cy).distance_to(Vector2(corner_r, corner_r)) > corner_r
			elif cx > sw - corner_r and cy < corner_r:
				in_corner = Vector2(cx, cy).distance_to(Vector2(sw - corner_r, corner_r)) > corner_r
			elif cx < corner_r and cy > sh - corner_r:
				in_corner = Vector2(cx, cy).distance_to(Vector2(corner_r, sh - corner_r)) > corner_r
			elif cx > sw - corner_r and cy > sh - corner_r:
				in_corner = Vector2(cx, cy).distance_to(Vector2(sw - corner_r, sh - corner_r)) > corner_r

			if in_corner:
				img.set_pixel(x, y, mortar)
				continue

			var base = stone_a if (row + col) % 2 == 0 else stone_b
			var noise = randf_range(-0.03, 0.03)

			img.set_pixel(x, y, Color(
				clamp(base.r + noise, 0.0, 1.0),
				clamp(base.g + noise, 0.0, 1.0),
				clamp(base.b + noise, 0.0, 1.0)
			))

	return ImageTexture.create_from_image(img)

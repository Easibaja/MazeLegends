# Generated by AI

class_name TextureGenerator

# ─── PICKING ──────────────────────────────────────────────────────────────────

static func pick_wall(dominant: int, pool: Array, alt_chance: float) -> ImageTexture:
	return _pick(pool, dominant, alt_chance)

static func pick_floor(dominant: int, pool: Array, alt_chance: float) -> ImageTexture:
	return _pick(pool, dominant, alt_chance)

static func _pick(pool: Array, dominant: int, alt_chance: float) -> ImageTexture:
	if randf() < alt_chance:
		var alts = range(pool.size()).filter(func(i): return i != dominant)
		return pool[alts[randi() % alts.size()]]
	return pool[dominant]

# ─── WALL TEXTURES — red-brown family ─────────────────────────────────────────

